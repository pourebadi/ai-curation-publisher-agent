# Runtime
ENVIRONMENT=
LOG_LEVEL=

# Cloudflare D1
D1_DATABASE_NAME=
D1_DATABASE_ID=

# Telegram
# Set secrets only in local .dev.vars or deployment secrets.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_REVIEW_CHAT_ID=
TELEGRAM_FINAL_CHAT_ID=
TELEGRAM_ALLOWED_REVIEWER_IDS=
TELEGRAM_REAL_REVIEW_ENABLED=false
TELEGRAM_FINAL_PUBLISH_ENABLED=false
TELEGRAM_PUBLISH_SCHEDULER_ENABLED=false
TELEGRAM_PUBLISH_DUE_LIMIT=5

# Media processing
MEDIA_PROCESSING_MODE=telegram_file_id_reuse
# Set MEDIA_PROCESSING_MODE=github_actions and GITHUB_MEDIA_PROCESSOR_ENABLED=true after manual Telegram flow works.
GITHUB_MEDIA_PROCESSOR_ENABLED=false
GITHUB_MEDIA_PROCESSOR_REPOSITORY=pourebadi/ai-curation-publisher-agent
GITHUB_MEDIA_PROCESSOR_WORKFLOW_ID=media-processor.yml
GITHUB_MEDIA_PROCESSOR_REF=main
GITHUB_MEDIA_PROCESSOR_CALLBACK_URL=https://your-worker.workers.dev/internal/media/processing/callback
# Store this as a Worker secret in production. It needs GitHub Actions workflow dispatch permission.
GITHUB_MEDIA_PROCESSOR_TOKEN=
# Backward-compatible aliases accepted by older helpers.
GITHUB_MEDIA_WORKFLOW_ENABLED=false
GITHUB_MEDIA_WORKFLOW_DISPATCH_ENABLED=false
GITHUB_MEDIA_REPO=
GITHUB_MEDIA_WORKFLOW_ID=media-processor.yml
GITHUB_MEDIA_WORKFLOW_REF=main
GITHUB_TOKEN=
WORKER_PUBLIC_BASE_URL=
TELEGRAM_MEDIA_MAX_PHOTO_MB=9
TELEGRAM_MEDIA_MAX_FILE_MB=49
# false = text-only/social links without downloadable media are skipped, not failed.
# true = missing external media fails the output.
MEDIA_PROCESSING_STRICT=false
GITHUB_MEDIA_PROCESSOR_STRICT=false
TELEGRAM_MEDIA_STAGING_CHAT_ID=
TELEGRAM_MEDIA_STAGING_THREAD_ID=
TELEGRAM_MEDIA_CACHE_CHAT_ID=
TELEGRAM_MEDIA_CACHE_THREAD_ID=
# GitHub Actions secrets required by .github/workflows/media-processor.yml:
# TELEGRAM_BOT_TOKEN
# TELEGRAM_MEDIA_CACHE_CHAT_ID or TELEGRAM_MEDIA_STAGING_CHAT_ID
# TELEGRAM_MEDIA_CACHE_THREAD_ID optional
# WORKER_INTERNAL_API_SECRET or INTERNAL_API_SECRET
# INSTAGRAM_COOKIES_B64 optional
# X_COOKIES_B64 optional

# WordPress
# Set these only in local .dev.vars or deployment secrets.
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
WORDPRESS_DEFAULT_STATUS=draft

# AI
# Set secrets only in local .dev.vars or deployment secrets.
AI_PROVIDER=mock
AI_MODEL=mock
AI_MODEL_FALLBACKS=[]
AI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
CUSTOM_AI_API_KEY=

# External providers
# Set these only in local .dev.vars or deployment secrets.
APIFY_TOKEN=
GETXAPI_KEY=
FIRECRAWL_API_KEY=
